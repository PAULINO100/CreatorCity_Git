# --- ATLAS CITY ENVIRONMENT CONFIG ---

# MODE: internal/dev (SQLite) or production (Postgres)
PROJECT_MODE=internal/dev

# DATABASE
# Local: file:./dev.db
# Prod: postgresql://[user]:[password]@[host]/[db]
DATABASE_URL="file:./dev.db"
DIRECT_URL="" # Required for Supabase/Postgres pooling in prod

# AUTHENTICATION
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="your-32-char-secret"

# GITHUB OAUTH
GITHUB_ID="your-github-id"
GITHUB_SECRET="your-github-secret"

# PLATFORM DIS SCALES
GITHUB_WEIGHT=1.0
YOUTUBE_WEIGHT=0.5
REDDIT_WEIGHT=0.2
